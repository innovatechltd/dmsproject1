{
  "name": "dms",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "services/*/backend",
    "services/*/frontend"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "db": "node scripts/db.js",
    "db:setup": "node scripts/db-setup.js",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.2",
    "embedded-postgres": "17.10.0-beta.17",
    "pg": "^8.13.1"
  }
}
