# All values below are the defaults baked into the code — you only need a .env
# file if you want to override them (e.g. point at a real PostgreSQL server).

# PostgreSQL connection (defaults match the embedded dev database)
#PGHOST=localhost
#PGPORT=5544
#PGDATABASE=dms
#PGPASSWORD=devpassword

# Where non-auth services fetch the auth service's public key from
#AUTH_URL=http://localhost:4001
